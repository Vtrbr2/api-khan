//primeiro faz loguin na edusp
import express from "express";
import fetch from "node-fetch";
import cors from "cors";
import dotenv from "dotenv";

dotenv.config();

const EDUSP_API = "https://edusp-api.ip.tv";

const app = express();
app.use(cors());
app.use(express.json());

const PORT = process.env.PORT || 3000;

// ============================================
// 🔐 LOGIN EDUSP
// ============================================
app.post("/registration/edusp", async (req, res) => {
    const { id, password } = req.body;

    if (!id || !password) {
        return res.status(400).json({
            errors: [{
                status: 400,
                title: "Dados incompletos",
                detail: "Usuário e senha são obrigatórios"
            }]
        });
    }

    try {
        console.log(`[LOGIN] Tentando autenticar: ${id}`);

        const response = await fetch(`${EDUSP_API}/registration/edusp`, {
            method: "POST",
            headers: {
                "Accept": "application/json",
                "Content-Type": "application/json",
                "x-api-realm": "edusp",
                "x-api-platform": "webclient",
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
                "Origin": "https://cmsp.ip.tv",
                "Referer": "https://cmsp.ip.tv/"
            },
            body: JSON.stringify({
                realm: "edusp",
                platform: "webclient",
                id,
                password
            })
        });

        const text = await response.text();

        if (text.startsWith("<")) {
            console.error("[LOGIN] HTML recebido");
            return res.status(401).json({
                errors: [{
                    status: 401,
                    title: "Autenticação falhou",
                    detail: "Credenciais inválidas"
                }]
            });
        }

        const data = JSON.parse(text);

        if (!response.ok || !data.auth_token) {
            console.log(`[LOGIN FALHOU] ${id}`);
            return res.status(401).json({
                errors: [{
                    status: 401,
                    title: "Autenticação falhou",
                    detail: "Credenciais inválidas"
                }]
            });
        }

        console.log(`[LOGIN SUCESSO] ${id}`);

        return res.json({
            auth_token: data.auth_token,
            nick: data.name || id,
            user: {
                name: data.name,
                login: id,
                nick: data.nick,
                role: data.role
            }
        });

    } catch (err) {
        console.error("[ERRO LOGIN]", err.message);
        return res.status(500).json({
            errors: [{
                status: 500,
                title: "Erro interno",
                detail: "Erro ao processar login"
            }]
        });
    }
});

